{
  "expo": {
    "name": "TuiTemplateNative",
    "slug": "tui-template-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "tuitemplatenative",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bootlegyouki.tuitemplatenative",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon.png",
        "tinted": "./assets/adaptive-icon-monochrome.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon-monochrome.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F4F4F5",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#18181B"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow the app to access the camera."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow the app to access your photo library.",
          "savePhotosPermission": "Allow the app to save images to your library."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow the app to access your photo library."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow the app to authenticate using FaceID."
        }
      ],
      "expo-share-extension"
    ]
  }
}
